# ===================
# Core Configuration
# ===================
AGENT_TOKEN=your-secure-token
GOOGLE_AI_API_KEY=your-google-ai-api-key

# AI Model (gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash, etc.)
AGENT_ADK_MODEL=gemini-2.0-flash
# Enable/disable AI chat
AGENT_ADK_ENABLED=true
# Working directory for command execution
AGENT_WORKING_DIR=/tmp
# Default shell for commands
AGENT_DEFAULT_SHELL=/bin/sh
# Max concurrent executions
AGENT_MAX_CONCURRENT=5
# Enable H2 database console (disable in production)
H2_CONSOLE_ENABLED=false

# ===================
# Slack Skill
# ===================
# App-Level Token for Socket Mode (starts with xapp-)
SLACK_APP_TOKEN=
# Bot User OAuth Token (starts with xoxb-)
SLACK_BOT_TOKEN=
# Incoming Webhook URL (optional, for simple notifications)
SLACK_WEBHOOK_URL=
# Default channel for messages
SLACK_DEFAULT_CHANNEL=
# Slash command name (without /)
SLACK_SLASH_COMMAND=

# ===================
# Gmail SMTP Skill
# ===================
# Your Gmail address
GMAIL_EMAIL=
# Gmail App Password (generate at myaccount.google.com/apppasswords)
GMAIL_APP_PASSWORD=
# Default recipient (optional)
GMAIL_DEFAULT_RECIPIENT=

# ===================
# Gmail API Skill (OAuth2)
# ===================
# Google OAuth 2.0 Client ID from Google Cloud Console
GMAIL_API_CLIENT_ID=
# Google OAuth 2.0 Client Secret
GMAIL_API_CLIENT_SECRET=

# ===================
# SMTP Skill
# ===================
# SMTP server hostname
SMTP_HOST=
# SMTP port (587 for TLS, 465 for SSL, 25 for plain)
SMTP_PORT=587
# SMTP username or API key
SMTP_USERNAME=
# SMTP password or API secret
SMTP_PASSWORD=
# Sender email address
SMTP_FROM_EMAIL=
# Sender display name (optional)
SMTP_FROM_NAME=
# Encryption: TLS, SSL, or NONE
SMTP_ENCRYPTION=TLS
# Default recipient (optional)
SMTP_DEFAULT_RECIPIENT=

# ===================
# Wingman Skill
# ===================
# Your name (for personalized responses)
FLIRT_USER_NAME=
# Flirting style: playful, witty, romantic, bold, subtle, mysterious
FLIRT_STYLE=playful
# Who you're interested in
FLIRT_INTERESTED_IN=
# Your personality/vibe
FLIRT_PERSONALITY=

# ===================
# Web Search Skill (Google Custom Search)
# ===================
# Google Cloud API Key with Custom Search API enabled
# Create at: https://console.cloud.google.com/apis/credentials
WEB_SEARCH_API_KEY=
# Custom Search Engine ID (cx parameter)
# Create at: https://programmablesearchengine.google.com/
WEB_SEARCH_ENGINE_ID=
